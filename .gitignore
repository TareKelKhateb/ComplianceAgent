# =============================================================================
# Data and Database (tracked via DVC)
# =============================================================================
# Ignore all files in /data/ EXCEPT .dvc pointer files
/data/**
!/data/.dvc/
!/data/.gitkeep
!/data/**/*.dvc
!/data/**/*.dvc.yaml

# Database file - tracked via Git (small metadata only)
# Uncomment if you want Git versioning:
# !/data/legal_vault.db

# =============================================================================
# DVC Internal Files
# =============================================================================
.dvc/cache/
.dvc/tmp/
.dvc/config.local
dvc.lock

# =============================================================================
# Python Environment and Cache
# =============================================================================
.venv/
venv/
env/
.env
.python-version
*.pyc
__pycache__/
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
dist/
build/

# =============================================================================
# IDE and Editor
# =============================================================================
.vscode/
.idea/
.vscode/settings.json
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Temporary Files
# =============================================================================
*.tmp
*.temp
.cache/
.coverage
htmlcov/

# =============================================================================
# Project-Specific
# =============================================================================
# Exclude specific config overrides (if any)
# config.local.yaml
# secrets.yaml
